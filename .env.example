AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
MC_SERVER_HOST=localhost
MC_SERVER_PORT=25565
MC_BOT_USERNAME=MineBenchBot
# Dual mode (node bench.js --task X --model-a A --model-b B) runs two bots side-by-side.
# Each gets one of these usernames; BOTH must be op'd on the server (/op <name>).
MC_BOT_USERNAME_A=MineBenchBotA
MC_BOT_USERNAME_B=MineBenchBotB
# Optional: ms the orchestrator waits for both dual-mode runs before timing out.
# DUAL_WAIT_MS=720000